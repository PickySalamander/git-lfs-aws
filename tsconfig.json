{
	"$schema": "https://json.schemastore.org/tsconfig",
	"extends": "@tsconfig/node24/tsconfig.json",
	"compilerOptions": {
		"lib": ["dom", "dom.iterable", "esnext"],
		"types": ["node"],
		"declaration": true,
		"strictNullChecks": false,
		"module": "esnext",
		"moduleResolution": "bundler"
	},
	"include": [
		"src/**/*.ts"
	]
}
